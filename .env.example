# URL de connexion PostgreSQL (Neon.tech)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Port du serveur
PORT=5000

# URL du frontend (pour CORS)
FRONTEND_URL=https://porfolio-aida.vercel.app

# Clé secrète JWT (change cette valeur !)
JWT_SECRET=change-me-to-a-random-string

# Hash du mot de passe admin (générer avec: node -e "console.log(require('bcryptjs').hashSync('tonmotdepasse', 10))")
ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
