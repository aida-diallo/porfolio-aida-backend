# URL de connexion MySQL
# Format : mysql://utilisateur:motdepasse@host:port/nom_base
DATABASE_URL=mysql://root:password@localhost:3306/portfolio_aida

# Port du serveur
PORT=5000

# URL du frontend (pour CORS en production)
FRONTEND_URL=https://porfolio-aida.vercel.app

# SSL pour la base de données (mettre true si hébergement distant)
DB_SSL=false
